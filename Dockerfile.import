FROM golang:1.25-alpine AS builder

# Install build dependencies
RUN apk add --no-cache gcc musl-dev sqlite-dev build-base bash

# Set working directory
WORKDIR /app

# Copy go mod and sum files
COPY go.mod go.sum ./

# Download dependencies (module cache persists across builds via BuildKit cache mount)
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

# Copy source code
COPY . .

# Build all the import binaries
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=1 GOOS=linux go build -o /app/bin/import-matchcards ./cmd/import-matchcards \
    && CGO_ENABLED=1 GOOS=linux go build -o /app/bin/import-tennis-players ./cmd/import-tennis-players

# Final stage - lightweight image with pre-built binaries (pinned Alpine)
FROM alpine:3.23

# Install runtime dependencies
RUN apk add --no-cache bash sqlite-libs ca-certificates

# Copy binaries from builder
COPY --from=builder /app/bin/ /usr/local/bin/

# Set working directory
WORKDIR /app

# Default command
CMD ["bash"] 